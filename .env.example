# Supabase — Project Settings → API
# Copy to .env and fill in. Then run: npm run build
#
# Vercel: add SUPABASE_URL and SUPABASE_ANON_KEY under Project → Settings →
# Environment Variables (Production + Preview). `npm run build` injects them
# into static/js/supabase-runtime.js and assembles HTML from src/ on each deploy.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=ART
